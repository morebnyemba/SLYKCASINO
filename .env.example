# =============================================================================
#  SLYK CASINO — environment. Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# Public domain that serves BOTH the Player UI (/) and Admin UI (/admin-portal).
DOMAIN=slykcasino.com

# Email used for Let's Encrypt registration / expiry notices.
CERTBOT_EMAIL=admin@slykcasino.com

# --- Postgres ---
POSTGRES_DB=slyk
POSTGRES_USER=slyk
POSTGRES_PASSWORD=change-me-strong-password

# --- Django ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-django-secret
# Optional: auto-create the raw-DB-access superuser on first container boot.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@slykcasino.com
DJANGO_SUPERUSER_PASSWORD=change-me-superuser-password

# --- Payment & KYC providers ---
PSP_PROVIDER=stub  # Options: stub, stripe
KYC_PROVIDER=stub  # Options: stub, onfido

# NOTE: NEXT_PUBLIC_* values are NOT set here — they are baked into the frontend
# images at build time and are derived from DOMAIN inside docker-compose.yml.
